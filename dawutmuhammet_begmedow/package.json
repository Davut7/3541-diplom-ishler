{
  "name": "virusdetect-pro",
  "version": "1.0.0",
  "description": "Advanced Malware Detection Desktop Application",
  "main": "electron/main.js",
  "author": "Dawutmuhammet Begmedow",
  "scripts": {
    "start": "electron .",
    "dev": "concurrently \"cd backend && node server.js\" \"cd frontend && npm run dev\" \"wait-on http://localhost:7040 && electron .\"",
    "dev:electron": "concurrently \"cd frontend && npm run dev\" \"wait-on http://localhost:7040 && electron .\"",
    "dev:web": "concurrently \"cd backend && node server.js\" \"cd frontend && npm run dev\"",
    "build": "cd frontend && npm run build && electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "electron-store": "^8.1.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.0",
    "electron": "^28.3.3",
    "electron-builder": "^24.9.1",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.dawut.virusdetect",
    "productName": "VirusDetect Pro",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "frontend/dist/**/*"
    ],
    "mac": {
      "category": "public.app-category.utilities",
      "icon": "assets/icon.icns"
    },
    "win": {
      "icon": "assets/icon.ico"
    },
    "linux": {
      "icon": "assets/icon.png",
      "category": "Utility"
    }
  }
}
